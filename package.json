{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:zh": "hexo generate --config _config.yml,config-zh.yml",
    "build:en": "hexo generate --config _config.yml,config-en.yml --force",
    "build": "node scripts/build-multilingual.js",
    "check:multilingual": "python ci_tools/check_translation_taxonomy.py && python ci_tools/check_language_coverage.py --strict && python ci_tools/check_front_matter_consistency.py && python ci_tools/check_content_completeness.py",
    "preview": "npm run check:multilingual && npm run build && npm run server",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "server": "hexo server --config _config.yml,config-zh.yml"
  },
  "hexo": {
    "version": "8.1.2"
  },
  "dependencies": {
    "@neilsustc/markdown-it-katex": "^1.0.0",
    "hexo": "^8.1.2",
    "hexo-deployer-git": "^4.0.0",
    "hexo-filter-mermaid-diagrams": "^1.0.5",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-baidu-sitemap": "^0.1.9",
    "hexo-generator-category": "^1.0.0",
    "hexo-generator-feed": "^4.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-search": "^2.4.3",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-pdf": "^1.0.0",
    "hexo-reference": "^1.0.4",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-markdown-it": "^7.1.1",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-butterfly": "^5.5.5",
    "hexo-theme-landscape": "^1.1.0",
    "hexo-wordcount": "^6.0.1",
    "valine": "^1.5.3",
    "which": "^6.0.1"
  }
}
